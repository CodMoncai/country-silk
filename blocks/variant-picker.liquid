{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
-%}

{% liquid
  assign enable_collection_context_variant = false
  if request.page_type == 'collection'
    assign enable_collection_context_variant = true
  endif
%}
{% unless product_resource == blank %}
  {% render 'variant-main-picker',
    product_resource: product_resource,
    block: block,
    enable_collection_context_variant: enable_collection_context_variant
  %}
{% endunless %}

{% schema %}
{
  "name": "t:names.product_variant_picker",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_variant_picker"
    },
    {
      "type": "paragraph",
      "content": "t:content.edit_variants_in_theme_settings"
    },
    {
      "type": "select",
      "id": "variant_style",
      "label": "t:settings.style",
      "options": [
        {
          "value": "dropdowns",
          "label": "t:options.dropdowns"
        },
        {
          "value": "buttons",
          "label": "t:options.buttons"
        }
      ],
      "default": "buttons"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "t:settings.swatches",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.theme_theme_swatches_header"
    },
    {
      "type": "paragraph",
      "content": "t:content.theme_theme_swatches_intro"
    },
    {
      "type": "text",
      "id": "theme_option_label",
      "label": "t:settings.theme_option_label",
      "default": "Theme,Themes",
      "info": "t:info.theme_option_label"
    },
    {
      "type": "header",
      "content": "t:content.priority_theme_option_values_header"
    },
    {
      "type": "paragraph",
      "content": "t:info.priority_theme_checkbox_group_intro"
    },
    {
      "type": "checkbox",
      "id": "priority_theme_enchanted_christmas",
      "label": "t:settings.priority_theme_enchanted_christmas",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_emerald_christmas",
      "label": "t:settings.priority_theme_emerald_christmas",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_festive_christmas",
      "label": "t:settings.priority_theme_festive_christmas",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_traditional_christmas",
      "label": "t:settings.priority_theme_traditional_christmas",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_traditional",
      "label": "t:settings.priority_theme_traditional",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_cozy_christmas",
      "label": "t:settings.priority_theme_cozy_christmas",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_candy",
      "label": "t:settings.priority_theme_candy",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_peppermint",
      "label": "t:settings.priority_theme_peppermint",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_specials",
      "label": "t:settings.priority_theme_specials",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_ruby_red_christmas",
      "label": "t:settings.priority_theme_ruby_red_christmas",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "priority_theme_non_theme",
      "label": "t:settings.priority_theme_non_theme",
      "default": false
    },
    {
      "type": "textarea",
      "id": "priority_theme_option_values",
      "label": "t:settings.priority_theme_option_values",
      "info": "t:info.priority_theme_option_values"
    },
    {
      "type": "text",
      "id": "theme_swatches_metafield_namespace",
      "label": "t:settings.theme_swatches_metafield_namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "theme_swatches_metafield_key",
      "label": "t:settings.theme_swatches_metafield_key",
      "default": "theme_swatches",
      "info": "t:info.theme_swatches_metafield_key"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_variant_picker",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
