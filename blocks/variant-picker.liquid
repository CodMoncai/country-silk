{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
  assign _variant_picker_scope_collection = collection
  if _variant_picker_scope_collection == blank and closest.collection != blank
    assign _variant_picker_scope_collection = closest.collection
  endif
-%}

{% capture _theme_sku_layout_flag %}{% render 'collection-theme-sku-layout-active', scope_collection: _variant_picker_scope_collection %}{% endcapture %}
{% liquid
  assign enable_collection_context_variant = false
  if _theme_sku_layout_flag | strip == '1'
    assign enable_collection_context_variant = true
  endif
%}
{% unless product_resource == blank %}
  {% render 'variant-main-picker',
    product_resource: product_resource,
    block: block,
    enable_collection_context_variant: enable_collection_context_variant
  %}
{% endunless %}

{% schema %}
{
  "name": "t:names.product_variant_picker",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_variant_picker"
    },
    {
      "type": "paragraph",
      "content": "t:content.edit_variants_in_theme_settings"
    },
    {
      "type": "select",
      "id": "variant_style",
      "label": "t:settings.style",
      "options": [
        {
          "value": "dropdowns",
          "label": "t:options.dropdowns"
        },
        {
          "value": "buttons",
          "label": "t:options.buttons"
        }
      ],
      "default": "buttons"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "t:settings.swatches",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.theme_theme_swatches_header"
    },
    {
      "type": "paragraph",
      "content": "t:content.theme_theme_swatches_intro"
    },
    {
      "type": "text",
      "id": "theme_option_label",
      "label": "t:settings.theme_option_label",
      "default": "Theme,Themes",
      "info": "t:info.theme_option_label"
    },
    {
      "type": "text",
      "id": "theme_swatches_metafield_namespace",
      "label": "t:settings.theme_swatches_metafield_namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "theme_swatches_metafield_key",
      "label": "t:settings.theme_swatches_metafield_key",
      "default": "theme_swatches",
      "info": "t:info.theme_swatches_metafield_key"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_variant_picker",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
