<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height calculation to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight() and updateTransparentHeaderOffset()utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    <script>
      (function() {
        var params = new URLSearchParams(window.location.search);
        var bypassValue = params.get('members_only_bypass');
        if (!bypassValue) {
          return;
        }

        var currentOrigin = window.location.origin;

        function shouldPreserve(href) {
          if (!href) return false;
          if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('javascript:')) {
            return false;
          }
          try {
            var target = new URL(href, currentOrigin);
            return target.origin === currentOrigin;
          } catch (error) {
            return false;
          }
        }

        function appendBypass(href) {
          try {
            var target = new URL(href, currentOrigin);
            if (!target.searchParams.has('members_only_bypass')) {
              target.searchParams.set('members_only_bypass', bypassValue);
            }
            return target.href;
          } catch (error) {
            return href;
          }
        }

        document.querySelectorAll('a[href]').forEach(function(anchor) {
          var href = anchor.getAttribute('href');
          if (!shouldPreserve(href)) return;
          anchor.setAttribute('href', appendBypass(href));
        });

        document.querySelectorAll('form[action]').forEach(function(form) {
          var action = form.getAttribute('action') || window.location.pathname;
          if (!shouldPreserve(action)) return;
          if (form.method && form.method.toLowerCase() === 'get') {
            var hiddenInput = document.createElement('input');
            hiddenInput.type = 'hidden';
            hiddenInput.name = 'members_only_bypass';
            hiddenInput.value = bypassValue;
            form.appendChild(hiddenInput);
          } else {
            form.setAttribute('action', appendBypass(action));
          }
        });

        var bypassStyle = document.createElement('style');
        bypassStyle.textContent = [
          '.price, .compare-at-price, .unit-price, .price-range, .volume-pricing-note, .cart__original-total-label, .cart__original-total-value, .cart__total-label, .cart__total-value, .header-actions__cart-total, .quick-order-list__grid-cell--total, .quick-order-list-total__price, .quick-order-list-total__subtotal-value, .quick-order-list-total__subtotal, .variant-item__total-price, .product-price__column--price, .product-price__column--total, text-component[ref="cartTotal"] { display: none !important; }',
          '.price::before, .compare-at-price::before, .unit-price::before, .price-range::before { content: none !important; }'
        ].join(' ');
        document.head.appendChild(bypassStyle);

        function hidePriceTotalLabels() {
          var labels = ['price', 'total', 'estimated total', 'subtotal', 'product subtotal', 'product total'];
          document.querySelectorAll('span,div,p,label,button,th,td').forEach(function(el) {
            var text = (el.textContent || '').trim().toLowerCase();
            if (!text) return;
            if (labels.indexOf(text) !== -1) {
              el.style.setProperty('display', 'none', 'important');
              return;
            }
            labels.forEach(function(label) {
              if (text === label || text === label + ':' || text.indexOf(label + ' ') === 0 || text.indexOf(label + ':') === 0) {
                el.style.setProperty('display', 'none', 'important');
              }
            });
          });
        }

        hidePriceTotalLabels();
        document.addEventListener('shopify:section:load', hidePriceTotalLabels);
      })();
    </script>
  </body>
</html>
