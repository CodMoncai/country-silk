{% unless customer %}
  <div class="section section--page-width color-{{ section.settings.color_scheme }}">
    <div class="members-only-gate">
      <svg
        class="members-only-gate__icon"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>

      <h1 class="members-only-gate__heading h3">Account Required</h1>
      <p class="members-only-gate__message">You must be logged in as a customer to browse this collection.</p>

      <div class="members-only-gate__actions">
        <a href="https://account.countrysilk.com" class="button">Log In</a>
        <a href="/pages/register" class="button-secondary">Create an Account</a>
      </div>
    </div>
  </div>

  <style>
    .members-only-gate-wrapper ~ .shopify-section {
      display: none !important;
    }
  </style>
{% endunless %}

{% stylesheet %}
  .members-only-gate {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-block: 80px;
    padding-inline: 20px;
    gap: 16px;
    min-height: 50vh;
  }

  .members-only-gate__icon {
    opacity: 0.6;
    margin-block-end: 8px;
  }

  .members-only-gate__heading {
    margin: 0;
  }

  .members-only-gate__message {
    max-width: 480px;
    margin: 0;
    opacity: 0.75;
    line-height: 1.6;
  }

  .members-only-gate__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-block-start: 16px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Members Only Gate",
  "class": "members-only-gate-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
