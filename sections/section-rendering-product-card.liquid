{% comment %}
  Section Rendering API only. Returns markup that must match the real variant picker so variant-picker.js can morph
  without stripping the form (a script-only stub would replace the full picker and hide all options).
{% endcomment %}

{% liquid
  if product == blank
    assign product = closest.product
  endif

  assign _srpc_ctx_collection = collection
  if _srpc_ctx_collection == blank and closest.collection != blank
    assign _srpc_ctx_collection = closest.collection
  endif

  capture _card_context_variant_id
    render 'card-context-variant-id', product: product, theme_option_label: section.settings.theme_option_label, current_collection: _srpc_ctx_collection
  endcapture
  assign _card_context_variant_id = _card_context_variant_id | strip
  assign card_context_variant = product.selected_or_first_available_variant
  if _card_context_variant_id != ''
    assign _want_srpc_vid = _card_context_variant_id | strip
    assign _resolved_card_variant = nil
    for v in product.variants
      assign _srpc_vid_s = v.id | append: ''
      if _srpc_vid_s == _want_srpc_vid
        assign _resolved_card_variant = v
        break
      endif
    endfor
    if _resolved_card_variant != blank
      assign card_context_variant = _resolved_card_variant
    endif
  endif

  if settings.transition_to_main_product
    assign featured_media_url = card_context_variant.featured_image | image_url: width: 500
    if featured_media_url == blank
      assign featured_media_url = product.featured_media.preview_image | image_url: width: 500
    endif
  endif

  assign url = card_context_variant.url
  unless url
    assign url = product.first_available_variant.url
  endunless
  unless url
    assign url = product.url
  endunless

  assign sku = card_context_variant.sku
%}

{%- if settings.transition_to_main_product -%}
  <product-card-link
    data-product-id="{{ product.id }}"
    data-featured-media-url="{{ featured_media_url }}"
    data-product-transition="{{ settings.transition_to_main_product }}"
  >
{%- endif -%}

<product-card>
  <a
    href="{{ url }}"
    ref="productCardLink"
  >
    {% render 'variant-main-picker',
      product_resource: product,
      block: section,
      enable_collection_context_variant: true
    %}
    {% render 'variant-swatches',
      product_resource: product,
      has_option_selected: true,
      swatch_block_id: section.id
    %}

    <product-price>
      {% render 'price', product_resource: product, show_unit_price: true %}
    </product-price>

    <product-sku-component
      data-product-id="{{ product.id }}"
      style="{% if sku == blank %}display: none;{% else %}display: block;{% endif %}"
    >
      {% render 'sku', product_resource: product %}
    </product-sku-component>
  </a>
</product-card>
{%- if settings.transition_to_main_product -%}
  </product-card-link>
{%- endif -%}

{% schema %}
{
  "name": "t:names.product_card_rendering",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:settings.product"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "variant_style",
      "label": "t:settings.style",
      "options": [
        {
          "value": "dropdowns",
          "label": "t:options.dropdowns"
        },
        {
          "value": "buttons",
          "label": "t:options.buttons"
        }
      ],
      "default": "buttons"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "t:settings.swatches",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.theme_theme_swatches_header"
    },
    {
      "type": "paragraph",
      "content": "t:content.theme_theme_swatches_intro"
    },
    {
      "type": "text",
      "id": "theme_option_label",
      "label": "t:settings.theme_option_label",
      "default": "Theme,Themes",
      "info": "t:info.theme_option_label"
    },
    {
      "type": "text",
      "id": "theme_swatches_metafield_namespace",
      "label": "t:settings.theme_swatches_metafield_namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "theme_swatches_metafield_key",
      "label": "t:settings.theme_swatches_metafield_key",
      "default": "theme_swatches",
      "info": "t:info.theme_swatches_metafield_key"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
