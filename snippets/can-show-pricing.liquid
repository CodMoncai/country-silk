{%- comment -%}
  Outputs "true" when pricing should be shown, otherwise nothing.
  Show pricing when: 
    - show_pricing parameter is in URL (shows RLP metafield prices)
    - theme editor (design_mode)
    - customer has tag "administrator"/"admin"
    - customer has custom.display_pricing set to true
  Pricing is always hidden when members_only_bypass is present on the URL.
  Metafield must have "Storefront access" enabled.
{%- endcomment -%}
{%- liquid
  assign bypass_members_only_pricing = false
  if request.url contains 'members_only_bypass' or request.query_string contains 'members_only_bypass'
    assign bypass_members_only_pricing = true
  endif

  assign show_pricing_mode = false
  if request.url contains 'show_pricing' or request.query_string contains 'show_pricing'
    assign show_pricing_mode = true
  endif

  if bypass_members_only_pricing
    echo ''
  elsif show_pricing_mode
    echo 'rlp_pricing'
  elsif request.design_mode
    echo 'true'
  elsif customer
    if customer.tags contains 'administrator' or customer.tags contains 'admin'
      echo 'true'
    else
      assign val = customer.metafields.custom.display_pricing.value
      assign direct = customer.metafields.custom.display_pricing
      if val == true or val == 'true' or val == '1'
        echo 'true'
      elsif direct == true or direct == 'true' or direct == '1'
        echo 'true'
      endif
    endif
  endif
-%}
