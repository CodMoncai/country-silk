{%- comment -%}
  Outputs "true" when pricing should be shown, otherwise nothing.
  Show pricing when: theme editor (design_mode) OR customer is logged in AND custom.display_pricing is not false.
  Only hide pricing when metafield is explicitly false/"false"/"0". If metafield is missing or true, show pricing.
{%- endcomment -%}
{%- liquid
  if request.design_mode
    echo 'true'
  elsif customer
    assign val = customer.metafields.custom.display_pricing.value
    assign direct = customer.metafields.custom.display_pricing
    comment
      Only hide when explicitly false. Default to show for logged-in customers when metafield is missing or true.
    endcomment
    if val == false or val == 'false' or val == '0' or direct == false or direct == 'false' or direct == '0'
      comment
        Do not show pricing
      endcomment
    else
      echo 'true'
    endif
  endif
-%}
