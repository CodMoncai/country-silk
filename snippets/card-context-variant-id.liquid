{%- doc -%}
  Returns the numeric id of the variant that should drive product card links, images, pricing, and swatches.

  Priority:
  1. product.selected_variant on product pages, or when facet filters are active (collection/search); otherwise not used on
     collection/search grids so Theme/collection matching can run.
  2. When storefront facet filters are active (collection or search): first available variant with
     variant.matched, else first matched variant (see Shopify variant.matched for filter context)
  3. On collection templates: Theme option uses product_option.position (not loop index), matches each option value name
     against the collection (contains / handle / multi-word overlap), normalizes common "Enchanted" misspellings, and prefers
     product_option_value.variant (combined listings). Else generic option1–option3 rules.
  4. Legacy tag URLs: current_tags matched against option1–option3, then variant title
  5. product.selected_or_first_available_variant

  Note: Facet filtering uses collection.filters / search.filters — not current_tags. Tag-only URLs use current_tags.

  @param {object} product - Product object (required)
  @param {string} [theme_option_label] - Comma-separated option names for Theme (same as variant picker), default Theme,Themes
{%- enddoc -%}
{%- liquid
  capture storefront_filters_active_capture
    render 'storefront-filters-active'
  endcapture
  assign storefront_filters_active_capture = storefront_filters_active_capture | strip
  assign storefront_filters_active = false
  if storefront_filters_active_capture == '1'
    assign storefront_filters_active = true
  endif

  if product.selected_variant and template.name == 'product'
    assign out_variant = product.selected_variant
  elsif product.selected_variant and storefront_filters_active
    assign out_variant = product.selected_variant
  elsif storefront_filters_active
    assign out_variant = product.selected_or_first_available_variant
    assign found_matched_available = false
    for variant in product.variants
      if variant.matched and variant.available
        assign out_variant = variant
        assign found_matched_available = true
        break
      endif
    endfor
    unless found_matched_available
      assign found_matched = false
      for variant in product.variants
        if variant.matched
          assign out_variant = variant
          assign found_matched = true
          break
        endif
      endfor
      unless found_matched
        assign out_variant = product.selected_or_first_available_variant
      endunless
    endunless
  elsif template.name == 'collection' and collection != blank
    assign out_variant = product.selected_or_first_available_variant
    assign found = false
    comment
      Normalize echnated/enchated so collection "Echnated …" matches variant "Enchated …" without breaking words like "technician".
    endcomment
    assign col_title_key = collection.title | downcase | strip | replace: 'echnated', 'enchated'
    assign col_handle = collection.handle | replace: 'echnated', 'enchated'
    assign col_title_handleized = collection.title | handleize | replace: 'echnated', 'enchated'
    assign col_cmp = collection.title | downcase | strip
    assign col_cmp = col_cmp | replace: 'ehnchanted', 'enchanted' | replace: 'ehchanted', 'enchanted' | replace: 'echnated', 'enchanted' | replace: 'enchated', 'enchanted'
    assign handle_cmp = col_handle | replace: 'ehnchanted', 'enchanted' | replace: 'ehchanted', 'enchanted' | replace: 'echnated', 'enchanted' | replace: 'enchated', 'enchanted'
    assign col_h_cmp = collection.title | handleize | replace: 'ehnchanted', 'enchanted' | replace: 'ehchanted', 'enchanted' | replace: 'echnated', 'enchanted' | replace: 'enchated', 'enchanted'
    assign theme_option_label_param = theme_option_label | default: 'Theme,Themes' | strip
    if theme_option_label_param == blank
      assign theme_option_label_param = 'Theme,Themes'
    endif
    assign theme_product_option = false
    assign theme_label_candidates = theme_option_label_param | split: ','
    for product_option in product.options_with_values
      assign opt_nm = product_option.name | downcase | strip
      for theme_label_part in theme_label_candidates
        assign part_norm = theme_label_part | strip | downcase
        if part_norm != blank and opt_nm == part_norm
          assign theme_product_option = product_option
          break
        endif
      endfor
      if theme_product_option != blank
        break
      endif
    endfor
    unless found
      if theme_product_option != blank
        assign theme_pos = theme_product_option.position
        for product_option_value in theme_product_option.values
          if found
            break
          endif
          assign vo_raw = product_option_value.name
          if vo_raw != blank
            assign vo = vo_raw | downcase | strip
            assign vo = vo | replace: 'ehnchanted', 'enchanted' | replace: 'ehchanted', 'enchanted' | replace: 'echnated', 'enchanted' | replace: 'enchated', 'enchanted'
            assign vo_h = vo_raw | handleize | replace: 'ehnchanted', 'enchanted' | replace: 'ehchanted', 'enchanted' | replace: 'echnated', 'enchanted' | replace: 'enchated', 'enchanted'
            assign matched_theme = false
            if vo.size >= 2
              if col_cmp contains vo
                assign matched_theme = true
              elsif col_cmp.size >= 3 and vo contains col_cmp
                assign matched_theme = true
              elsif col_h_cmp != blank and vo_h != blank and col_h_cmp contains vo_h
                assign matched_theme = true
              elsif handle_cmp != blank and vo_h != blank and handle_cmp contains vo_h
                assign matched_theme = true
              elsif col_h_cmp != blank and vo_h != blank and vo_h contains col_h_cmp
                assign matched_theme = true
              elsif handle_cmp != blank and vo_h != blank and vo_h contains handle_cmp
                assign matched_theme = true
              endif
            endif
            unless matched_theme
              if vo contains ' '
                assign tw_first = vo | split: ' ' | first
                assign tw_last = vo | split: ' ' | last
                if tw_first != tw_last and tw_first.size >= 4 and tw_last.size >= 4
                  if col_cmp contains tw_first and col_cmp contains tw_last
                    assign matched_theme = true
                  endif
                endif
              endif
            endunless
            if matched_theme
              assign vo_key_cmp = vo_raw | downcase | strip
              assign resolved_theme_variant = false
              for v in product.variants
                assign v_opt = ''
                case theme_pos
                  when 1
                    assign v_opt = v.option1
                  when 2
                    assign v_opt = v.option2
                  when 3
                    assign v_opt = v.option3
                endcase
                assign v_opt_key = v_opt | downcase | strip
                assign v_opt_norm = v_opt_key | replace: 'ehnchanted', 'enchanted' | replace: 'ehchanted', 'enchanted' | replace: 'echnated', 'enchanted' | replace: 'enchated', 'enchanted'
                if v_opt == vo_raw or v_opt_key == vo_key_cmp or v_opt_norm == vo
                  assign resolved_theme_variant = v
                  break
                endif
              endfor
              if resolved_theme_variant == false and product_option_value.variant != blank
                assign resolved_theme_variant = product_option_value.variant
              endif
              if resolved_theme_variant != blank
                assign out_variant = resolved_theme_variant
                assign found = true
                break
              endif
            endif
          endif
        endfor
      endif
    endunless
    for variant in product.variants
      if found
        break
      endif
      if col_title_key != blank
        if variant.option1 != blank and variant.option1 | downcase | strip | replace: 'echnated', 'enchated' == col_title_key
          assign out_variant = variant
          assign found = true
          break
        endif
        if variant.option2 != blank and variant.option2 | downcase | strip | replace: 'echnated', 'enchated' == col_title_key
          assign out_variant = variant
          assign found = true
          break
        endif
        if variant.option3 != blank and variant.option3 | downcase | strip | replace: 'echnated', 'enchated' == col_title_key
          assign out_variant = variant
          assign found = true
          break
        endif
      endif
    endfor
    unless found
      if col_handle != blank
        assign col_handle_words = col_handle | replace: '-', ' ' | downcase | strip
        for variant in product.variants
          if found
            break
          endif
          if variant.option1 != blank and variant.option1 | downcase | strip | replace: 'echnated', 'enchated' == col_handle_words
            assign out_variant = variant
            assign found = true
            break
          endif
          if variant.option2 != blank and variant.option2 | downcase | strip | replace: 'echnated', 'enchated' == col_handle_words
            assign out_variant = variant
            assign found = true
            break
          endif
          if variant.option3 != blank and variant.option3 | downcase | strip | replace: 'echnated', 'enchated' == col_handle_words
            assign out_variant = variant
            assign found = true
            break
          endif
        endfor
      endif
    endunless
    unless found
      if col_handle != blank
        for variant in product.variants
          if found
            break
          endif
          if variant.option1 != blank and variant.option1 | handleize | replace: 'echnated', 'enchated' == col_handle
            assign out_variant = variant
            assign found = true
            break
          endif
          if variant.option2 != blank and variant.option2 | handleize | replace: 'echnated', 'enchated' == col_handle
            assign out_variant = variant
            assign found = true
            break
          endif
          if variant.option3 != blank and variant.option3 | handleize | replace: 'echnated', 'enchated' == col_handle
            assign out_variant = variant
            assign found = true
            break
          endif
        endfor
      endif
    endunless
    unless found
      if col_title_handleized != blank
        for variant in product.variants
          if found
            break
          endif
          assign opt1h = variant.option1 | handleize | replace: 'echnated', 'enchated'
          assign opt2h = variant.option2 | handleize | replace: 'echnated', 'enchated'
          assign opt3h = variant.option3 | handleize | replace: 'echnated', 'enchated'
          if variant.option1 != blank and opt1h == col_title_handleized
            assign out_variant = variant
            assign found = true
            break
          endif
          if variant.option2 != blank and opt2h == col_title_handleized
            assign out_variant = variant
            assign found = true
            break
          endif
          if variant.option3 != blank and opt3h == col_title_handleized
            assign out_variant = variant
            assign found = true
            break
          endif
        endfor
      endif
    endunless
    unless found
      if col_title_key != blank and col_title_key.size >= 8
        for variant in product.variants
          if found
            break
          endif
          assign opt_blob = variant.option1 | append: ' ' | append: variant.option2 | append: ' ' | append: variant.option3 | downcase | strip | replace: 'echnated', 'enchated'
          if opt_blob contains col_title_key
            assign out_variant = variant
            assign found = true
            break
          endif
        endfor
      endif
    endunless
  elsif current_tags != blank and current_tags.size > 0
    assign out_variant = product.selected_or_first_available_variant
    assign found = false
    for variant in product.variants
      if found
        break
      endif
      for tag in current_tags
        assign tag_key = tag | downcase | strip
        if variant.option1 != blank and variant.option1 | downcase | strip == tag_key
          assign out_variant = variant
          assign found = true
          break
        endif
        if variant.option2 != blank and variant.option2 | downcase | strip == tag_key
          assign out_variant = variant
          assign found = true
          break
        endif
        if variant.option3 != blank and variant.option3 | downcase | strip == tag_key
          assign out_variant = variant
          assign found = true
          break
        endif
      endfor
    endfor
    unless found
      for variant in product.variants
        if found
          break
        endif
        for tag in current_tags
          assign tag_key = tag | downcase | strip
          if variant.title != blank and variant.title | downcase | strip == tag_key
            assign out_variant = variant
            assign found = true
            break
          endif
        endfor
      endfor
    endunless
  else
    assign out_variant = product.selected_or_first_available_variant
  endif
-%}
{{- out_variant.id -}}
