{%- doc -%}
  Outputs "1" when Country Silk collection theme SKU rules should apply (card variant, picker order, etc.).

  Active when a collection reference exists and:
  - request.page_type is collection, except the non-theme collection template, OR
  - template is the collections-theme alternate (suffix / name).

  @param {object} [scope_collection] - Collection to use when global collection is unset (e.g. pass from parent snippet).
{%- enddoc -%}
{%- liquid
  assign col = collection
  if col == blank and scope_collection != blank
    assign col = scope_collection
  endif
  if col == blank and closest.collection != blank
    assign col = closest.collection
  endif

  assign active = false
  if col != blank
    if template.name contains 'non-theme-collection'
      assign active = false
    elsif request.page_type == 'collection'
      assign active = true
    elsif template.suffix == 'collections-theme' or template.name contains 'collections-theme'
      assign active = true
    endif
  endif
-%}
{%- if active -%}1{%- endif -%}
