{%- doc -%}
  For collection pages: picks a variant when Variant SKU ends with a Theme Code (suffix match).
  Collection URLs use hyphenated handles (e.g. traditional-christmas, ruby-red-christmas).

  Dedicated collections → single code (or TR2 then TRA for Traditional):
  - Peppermint → RW2
  - Candy → CND
  - Traditional Christmas → TR2, TRA
  - Cozy Christmas → BR2
  - Enchanted Christmas → BSW (title typo "Chrsitmas" normalized to match)
  - Ruby Red Christmas → RRD
  - Festive Christmas → FAS

  Specials → every other theme / palette code only (not the seven collections above):
  GWN, GLD, SWC, BRW, PGW, EMR, RSC, BUF, RRW2, RRW, GD2

  Theme table (suffix = last 3 characters of Variant SKU):
  | 18 | Peppermint              | RW2 |
  | 19 | Candy                   | CND |
  | 23 | Traditional Christmas   | TR2 |
  | 34 | Cozy Christmas          | BR2 |
  | 49 | Enchanted Christmas     | BSW |
  | 51 | Ruby Red Christmas      | RRD |
  | 52 | Festive Christmas       | FAS |

  @param {object} product - Product
  @param {object} collection - Current collection
{%- enddoc -%}
{%- liquid
  assign pick_id = ''
  assign ch = collection.handle | downcase | strip
  assign ct = collection.title | downcase | strip | replace: 'chrsitmas', 'christmas'
  assign codes_line = ''

  comment
    Match specific collections before Specials. Handles are hyphenated; titles include full theme names.
  endcomment
  if ch contains 'peppermint' or ct contains 'peppermint'
    assign codes_line = 'RW2'
  elsif ch contains 'candy' or ct == 'candy'
    assign codes_line = 'CND'
  elsif ch contains 'traditional' and (ch contains 'christmas' or ch contains 'xmas')
    assign codes_line = 'TR2,TRA'
  elsif ct contains 'traditional' and (ct contains 'christmas' or ct contains 'xmas')
    assign codes_line = 'TR2,TRA'
  elsif ch contains 'cozy' and (ch contains 'christmas' or ch contains 'xmas')
    assign codes_line = 'BR2'
  elsif ct contains 'cozy' and (ct contains 'christmas' or ct contains 'xmas')
    assign codes_line = 'BR2'
  elsif ch contains 'enchanted' and (ch contains 'christmas' or ch contains 'xmas')
    assign codes_line = 'BSW'
  elsif ct contains 'enchanted' and (ct contains 'christmas' or ct contains 'xmas')
    assign codes_line = 'BSW'
  elsif ch contains 'ruby' and ch contains 'red'
    assign codes_line = 'RRD'
  elsif ct contains 'ruby' and ct contains 'red' and (ct contains 'christmas' or ct contains 'xmas')
    assign codes_line = 'RRD'
  elsif ch contains 'festive' and (ch contains 'christmas' or ch contains 'xmas')
    assign codes_line = 'FAS'
  elsif ct contains 'festive' and (ct contains 'christmas' or ct contains 'xmas')
    assign codes_line = 'FAS'
  elsif ch == 'specials' or ch == 'special-offers' or ct == 'specials'
    assign codes_line = 'GWN,GLD,SWC,BRW,PGW,EMR,RSC,BUF,RRW2,RRW,GD2'
  endif

  if codes_line != blank
    assign code_parts = codes_line | split: ','
    for code_token in code_parts
      if pick_id != blank
        break
      endif
      assign code_u = code_token | strip | upcase
      if code_u == blank
        continue
      endif
      assign csize = code_u.size
      for variant in product.variants
        if pick_id != blank
          break
        endif
        assign sku_raw = variant.sku | strip
        if sku_raw == blank
          continue
        endif
        assign sku_u = sku_raw | upcase
        assign ssize = sku_u.size
        if ssize >= csize
          assign start_i = ssize | minus: csize
          assign suf = sku_u | slice: start_i, csize
          if suf == code_u
            assign pick_id = variant.id
            break
          endif
        endif
      endfor
    endfor
  endif
-%}
{{- pick_id -}}
