{%- comment -%}
  Renders hero video from an external URL. Supports:
  - Direct video files (.mp4, etc.) via native <video>
  - Vimeo URLs via iframe embed (autoplay, loop, muted)
  - YouTube URLs via iframe embed (autoplay, loop, muted)

  @param external_url {string} - The external video URL (Vimeo, YouTube, or direct file)
  @param video_class {string} - CSS class for the video/iframe element
  @param data_testid {string} - Optional data-testid value
  @param poster_image {image} - Optional image shown until iframe or external file video is ready
{%- endcomment -%}

{% liquid
  assign external_url = external_url | strip
  assign video_class = video_class | default: 'hero__video'
  assign data_testid = data_testid | default: ''

  assign video_id = ''
  assign video_type = ''
  assign vimeo_hash = ''

  if external_url != blank
    if external_url contains 'youtu.be'
      assign video_id = external_url | split: '/' | last | split: '?' | first
      assign video_type = 'youtube'
    elsif external_url contains 'youtube.com/embed/'
      assign video_id = external_url | split: 'embed/' | last | split: '?' | first | split: '&' | first
      assign video_type = 'youtube'
    elsif external_url contains 'youtube.com'
      assign video_id = external_url | split: 'v=' | last | split: '&' | first
      assign video_type = 'youtube'
    elsif external_url contains 'vimeo.com'
      assign vimeo_path = external_url | split: '?' | first | split: '#' | first
      assign vimeo_path_parts = vimeo_path | split: '/'
      for part in vimeo_path_parts reversed
        assign non_numeric_part = part
          | replace: '0', ''
          | replace: '1', ''
          | replace: '2', ''
          | replace: '3', ''
          | replace: '4', ''
          | replace: '5', ''
          | replace: '6', ''
          | replace: '7', ''
          | replace: '8', ''
          | replace: '9', ''
        if part != blank and non_numeric_part == blank
          assign video_id = part
          break
        endif
      endfor

      if external_url contains 'h='
        assign vimeo_hash = external_url | split: 'h=' | last | split: '&' | first
      endif

      assign video_type = 'vimeo'
    endif
  endif
%}

{% if video_type == 'vimeo' and video_id != blank %}
  {% capture vimeo_embed_src -%}
    https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&loop=1&background=1&autopause=0{% if vimeo_hash != blank %}&h={{ vimeo_hash }}{% endif %}
  {%- endcapture %}
  {% if poster_image != blank %}
    <div
      class="hero__video-iframe-wrapper {{ video_class }} hero__video-iframe-wrapper--deferred"
      data-hero-embed-src="{{ vimeo_embed_src | strip | escape }}"
      data-hero-iframe-class="{{ video_class | escape }}"
      data-hero-embed-allow="autoplay; fullscreen; picture-in-picture"
      {% if data_testid != blank %}
        data-hero-testid="{{ data_testid | escape }}"
      {% endif %}
    >
      {{
        poster_image
        | image_url: width: 1920
        | image_tag:
          width: poster_image.width,
          widths: '832, 1200, 1600, 1920',
          height: poster_image.height,
          class: 'hero__video-poster-embed',
          loading: 'eager',
          alt: ''
      }}
    </div>
  {% else %}
    <div class="hero__video-iframe-wrapper {{ video_class }}">
      <iframe
        src="{{ vimeo_embed_src | strip | escape }}"
        class="hero__video-iframe {{ video_class }}"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title="Hero background video"
        {% if data_testid != blank %}
          data-testid="{{ data_testid }}"
        {% endif %}
      ></iframe>
    </div>
  {% endif %}
{% elsif video_type == 'youtube' and video_id != blank %}
  {% capture youtube_embed_src -%}
    https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&loop=1&playlist={{ video_id }}&controls=0&rel=0&playsinline=1
  {%- endcapture %}
  {% if poster_image != blank %}
    <div
      class="hero__video-iframe-wrapper {{ video_class }} hero__video-iframe-wrapper--deferred"
      data-hero-embed-src="{{ youtube_embed_src | strip | escape }}"
      data-hero-iframe-class="{{ video_class | escape }}"
      data-hero-embed-allow="autoplay; encrypted-media; fullscreen"
      {% if data_testid != blank %}
        data-hero-testid="{{ data_testid | escape }}"
      {% endif %}
    >
      {{
        poster_image
        | image_url: width: 1920
        | image_tag:
          width: poster_image.width,
          widths: '832, 1200, 1600, 1920',
          height: poster_image.height,
          class: 'hero__video-poster-embed',
          loading: 'eager',
          alt: ''
      }}
    </div>
  {% else %}
    <div class="hero__video-iframe-wrapper {{ video_class }}">
      <iframe
        src="{{ youtube_embed_src | strip | escape }}"
        class="hero__video-iframe {{ video_class }}"
        allow="autoplay; encrypted-media; fullscreen"
        allowfullscreen
        title="Hero background video"
        {% if data_testid != blank %}
          data-testid="{{ data_testid }}"
        {% endif %}
      ></iframe>
    </div>
  {% endif %}
{% else %}
  <video
    autoplay
    loop
    muted
    playsinline
    class="{{ video_class }}"
    {% if poster_image != blank %}
      poster="{{ poster_image | image_url: width: 1920 }}"
    {% endif %}
    {% if data_testid != blank %}
      data-testid="{{ data_testid }}"
    {% endif %}
  >
    <source src="{{ external_url }}">
  </video>
{% endif %}
