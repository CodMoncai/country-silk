{%- doc -%}
  CSS color for the Theme swatch from metaobject fields only (not a product "Color" variant option).

  Tries: Color-type fields swatch_color, swatch_colour, theme_swatch_color, color (metaobject field name), swatch-color; then single-line hex fields hex, hex_code, swatch_hex, theme_hex. Unwraps .value when needed.

  @param {object} entry - Metaobject from theme swatch list
{%- enddoc -%}
{% liquid
  assign c_host = entry.swatch_color | default: entry.swatch_colour | default: entry.theme_swatch_color | default: entry.color | default: entry.colour | default: entry['swatch-color']
  assign c_obj = c_host
  if c_obj != blank and c_obj.rgb == blank and c_obj.hex == blank and c_obj.value != blank
    assign c_obj = c_obj.value
  endif
  if c_obj != blank and c_obj.rgb == blank and c_obj.hex == blank and c_obj.value != blank
    assign c_obj = c_obj.value
  endif
  assign out = ''
  if c_obj != blank
    if c_obj.rgb != blank
      assign out = 'rgb(' | append: c_obj.rgb | append: ')'
    elsif c_obj.hex != blank
      assign out = c_obj.hex
    else
      assign s = c_obj | append: '' | strip
      if s contains '#'
        assign out = s
      endif
    endif
  endif
  if out == blank
    assign t_hex = entry.hex | default: entry.hex_code | default: entry.swatch_hex | default: entry.theme_hex | strip
    if t_hex contains '#'
      assign out = t_hex
    endif
  endif
%}
{%- if out != blank -%}
  {{- out -}}
{%- elsif c_host != blank -%}
  {%- capture host_rendered -%}{{- c_host -}}{%- endcapture -%}
  {%- assign host_rendered = host_rendered | strip -%}
  {%- if host_rendered contains '#' -%}
    {{- host_rendered -}}
  {%- endif -%}
{%- endif -%}
