{%- doc -%}
  Builds comma-separated Theme priority names from checkbox settings (`priority_theme_*`).
  Order matches the fixed sequence in the theme editor. Falls back to legacy
  `priority_theme_option_values` when no checkboxes are checked (migration / edge cases).

  Use `picker_settings` (not `settings`) as the render argument name so this does not shadow
  Shopify’s global `settings` object (theme settings), which would make all checkbox reads fail.
  @param {object} picker_settings - `block.settings` or `section.settings`
{%- enddoc -%}
{% liquid
  assign line = ''
  if picker_settings.priority_theme_enchanted_christmas
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Enchanted Christmas'
  endif
  if picker_settings.priority_theme_emerald_christmas
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Emerald Christmas'
  endif
  if picker_settings.priority_theme_festive_christmas
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Festive Christmas'
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Festive Chistmas'
  endif
  if picker_settings.priority_theme_traditional_christmas
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Traditional Christmas'
  endif
  if picker_settings.priority_theme_traditional
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Traditional'
  endif
  if picker_settings.priority_theme_cozy_christmas
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Cozy Christmas'
  endif
  if picker_settings.priority_theme_candy
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Candy'
  endif
  if picker_settings.priority_theme_peppermint
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Peppermint'
  endif
  if picker_settings.priority_theme_specials
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Specials'
  endif
  if picker_settings.priority_theme_ruby_red_christmas
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Ruby Red Christmas'
  endif
  if picker_settings.priority_theme_non_theme
    if line != ''
      assign line = line | append: ','
    endif
    assign line = line | append: 'Non Theme'
  endif
  if line == blank
    assign line = picker_settings.priority_theme_option_values | default: '' | strip
  endif
-%}
{{- line -}}
