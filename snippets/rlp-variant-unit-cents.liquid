{%- doc -%}
  Resolves custom.rlp when custom.show_rlp is true (variant OR product).

  Money metafields use a Money drop: `| append: ''` is often empty — we stringify with
  capture/echo so cents parse reliably.

  Outputs: "FLAG,CENTS" — FLAG 1 when RLP is resolved, CENTS integer (0 when inactive).
  Payable amount is always variant.price in the parent snippet / JSON map.
{%- enddoc -%}
{%- liquid
  assign v = variant
  assign p = product

  assign v_show_mf = v.metafields.custom.show_rlp
  assign p_show_mf = p.metafields.custom.show_rlp

  assign v_show_raw = nil
  if v_show_mf != blank
    assign v_show_raw = v_show_mf.value
    if v_show_raw == blank
      assign v_show_raw = v_show_mf
    endif
  endif

  assign p_show_raw = nil
  if p_show_mf != blank
    assign p_show_raw = p_show_mf.value
    if p_show_raw == blank
      assign p_show_raw = p_show_mf
    endif
  endif

  assign rlp_applied = 0
  assign rlp_out = 0
  assign show_rlp_flag = false

  assign v_show_str = v_show_raw | append: '' | strip | downcase
  assign p_show_str = p_show_raw | append: '' | strip | downcase

  assign v_show_true = false
  if v_show_raw == true or v_show_str == 'true' or v_show_str == '1' or v_show_str == 'yes'
    assign v_show_true = true
  endif

  assign p_show_true = false
  if p_show_raw == true or p_show_str == 'true' or p_show_str == '1' or p_show_str == 'yes'
    assign p_show_true = true
  endif

  if v_show_true or p_show_true
    assign show_rlp_flag = true
  endif

  if show_rlp_flag
    assign rlp_cents = nil

    if v.metafields.custom.rlp != blank
      assign mf_v = v.metafields.custom.rlp
      assign raw_v = mf_v.value
      if raw_v == blank
        assign raw_v = mf_v
      endif
      assign t_v = mf_v.type | default: ''

      if t_v == 'money'
        capture cap_v
          echo raw_v
        endcapture
        assign rlp_cents = cap_v | strip | plus: 0
      elsif t_v == 'number_decimal'
        assign rlp_cents = raw_v | times: 100 | round
      elsif t_v == 'number_integer'
        assign rlp_cents = raw_v | plus: 0
      elsif t_v == 'single_line_text_field'
        assign cleaned_v = raw_v | strip | replace: '$', '' | replace: ',', ''
        assign rlp_cents = cleaned_v | times: 100 | round
      else
        assign rlp_num_v = raw_v | plus: 0
        capture cap_else_v
          echo raw_v
        endcapture
        assign str_v = cap_else_v | strip
        if str_v == ''
          assign str_v = raw_v | append: ''
        endif
        if str_v contains '.'
          assign rlp_cents = rlp_num_v | times: 100 | round
        else
          assign rlp_cents = rlp_num_v
        endif
      endif
    endif

    if rlp_cents == blank or rlp_cents <= 0
      if p.metafields.custom.rlp != blank
        assign mf_p = p.metafields.custom.rlp
        assign raw_p = mf_p.value
        if raw_p == blank
          assign raw_p = mf_p
        endif
        assign t_p = mf_p.type | default: ''

        if t_p == 'money'
          capture cap_p
            echo raw_p
          endcapture
          assign rlp_cents = cap_p | strip | plus: 0
        elsif t_p == 'number_decimal'
          assign rlp_cents = raw_p | times: 100 | round
        elsif t_p == 'number_integer'
          assign rlp_cents = raw_p | plus: 0
        elsif t_p == 'single_line_text_field'
          assign cleaned_p = raw_p | strip | replace: '$', '' | replace: ',', ''
          assign rlp_cents = cleaned_p | times: 100 | round
        else
          assign rlp_num_p = raw_p | plus: 0
          capture cap_else_p
            echo raw_p
          endcapture
          assign str_p = cap_else_p | strip
          if str_p == ''
            assign str_p = raw_p | append: ''
          endif
          if str_p contains '.'
            assign rlp_cents = rlp_num_p | times: 100 | round
          else
            assign rlp_cents = rlp_num_p
          endif
        endif
      endif
    endif

    if rlp_cents != blank and rlp_cents > 0
      assign rlp_applied = 1
      assign rlp_out = rlp_cents
    endif
  endif
-%}
{{- rlp_applied -}},{{- rlp_out -}}
