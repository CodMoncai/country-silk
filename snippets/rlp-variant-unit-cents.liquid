{%- doc -%}
  Resolves custom.rlp from variant (then product) when the logged-in customer has
  customer.metafields.custom.show_rlp true. RLP amounts stay on variant/product.

  Money drops: stringify with `{% capture %}{{ value }}{% endcapture %}` (not `echo` in liquid).

  Outputs: FLAG|CENTS (pipe delimiter). FLAG is 1 when RLP resolves; CENTS is integer.
{%- enddoc -%}
{%- liquid
  assign v = variant
  assign p = product

  assign show_rlp_raw = nil
  if customer
    assign c_show_mf = customer.metafields.custom.show_rlp
    if c_show_mf != blank
      assign show_rlp_raw = c_show_mf.value
      if show_rlp_raw == blank
        assign show_rlp_raw = c_show_mf
      endif
    endif
  endif

  assign rlp_applied = 0
  assign rlp_out = 0
  assign show_rlp_flag = false

  assign show_rlp_str = show_rlp_raw | append: '' | strip | downcase
  if show_rlp_raw == true or show_rlp_raw == 1 or show_rlp_str == 'true' or show_rlp_str == '1' or show_rlp_str == 'yes'
    assign show_rlp_flag = true
  endif

  assign rlp_cents = nil
-%}
{%- if show_rlp_flag -%}
  {%- if v.metafields.custom.rlp != blank -%}
    {%- assign mf_v = v.metafields.custom.rlp -%}
    {%- assign raw_v = mf_v.value -%}
    {%- if raw_v == blank -%}
      {%- assign raw_v = mf_v -%}
    {%- endif -%}
    {%- assign t_v = mf_v.type | default: '' -%}
    {%- if t_v == 'money' or t_v contains 'money' -%}
      {%- capture cap_money_v -%}{{ raw_v }}{%- endcapture -%}
      {%- assign s_v = cap_money_v | strip | replace: '$', '' | replace: ' ', '' | remove: ',' -%}
      {%- assign rlp_cents = s_v | plus: 0 -%}
      {%- if rlp_cents == 0 -%}
        {%- capture cap_mwc_v -%}{{ raw_v | money_without_currency }}{%- endcapture -%}
        {%- assign clean_v = cap_mwc_v | strip | replace: ',', '.' | replace: ' ', '' -%}
        {%- assign rlp_cents = clean_v | times: 100 | round -%}
      {%- endif -%}
    {%- elsif t_v == 'number_decimal' -%}
      {%- assign rlp_cents = raw_v | times: 100 | round -%}
    {%- elsif t_v == 'number_integer' -%}
      {%- assign rlp_cents = raw_v | plus: 0 -%}
    {%- elsif t_v == 'single_line_text_field' -%}
      {%- assign cleaned_v = raw_v | strip | replace: '$', '' | replace: ',', '' -%}
      {%- assign rlp_cents = cleaned_v | times: 100 | round -%}
    {%- else -%}
      {%- capture cap_else_v -%}{{ raw_v }}{%- endcapture -%}
      {%- assign str_v = cap_else_v | strip | remove: ',' -%}
      {%- assign num_v = str_v | plus: 0 -%}
      {%- if str_v contains '.' -%}
        {%- assign rlp_cents = num_v | times: 100 | round -%}
      {%- else -%}
        {%- assign rlp_cents = num_v -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

  {%- if rlp_cents == blank or rlp_cents <= 0 -%}
    {%- if p.metafields.custom.rlp != blank -%}
      {%- assign mf_p = p.metafields.custom.rlp -%}
      {%- assign raw_p = mf_p.value -%}
      {%- if raw_p == blank -%}
        {%- assign raw_p = mf_p -%}
      {%- endif -%}
      {%- assign t_p = mf_p.type | default: '' -%}
      {%- if t_p == 'money' or t_p contains 'money' -%}
        {%- capture cap_money_p -%}{{ raw_p }}{%- endcapture -%}
        {%- assign s_p = cap_money_p | strip | replace: '$', '' | replace: ' ', '' | remove: ',' -%}
        {%- assign rlp_cents = s_p | plus: 0 -%}
        {%- if rlp_cents == 0 -%}
          {%- capture cap_mwc_p -%}{{ raw_p | money_without_currency }}{%- endcapture -%}
          {%- assign clean_p = cap_mwc_p | strip | replace: ',', '.' | replace: ' ', '' -%}
          {%- assign rlp_cents = clean_p | times: 100 | round -%}
        {%- endif -%}
      {%- elsif t_p == 'number_decimal' -%}
        {%- assign rlp_cents = raw_p | times: 100 | round -%}
      {%- elsif t_p == 'number_integer' -%}
        {%- assign rlp_cents = raw_p | plus: 0 -%}
      {%- elsif t_p == 'single_line_text_field' -%}
        {%- assign cleaned_p = raw_p | strip | replace: '$', '' | replace: ',', '' -%}
        {%- assign rlp_cents = cleaned_p | times: 100 | round -%}
      {%- else -%}
        {%- capture cap_else_p -%}{{ raw_p }}{%- endcapture -%}
        {%- assign str_p = cap_else_p | strip | remove: ',' -%}
        {%- assign num_p = str_p | plus: 0 -%}
        {%- if str_p contains '.' -%}
          {%- assign rlp_cents = num_p | times: 100 | round -%}
        {%- else -%}
          {%- assign rlp_cents = num_p -%}
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

  {%- if rlp_cents != blank and rlp_cents > 0 -%}
    {%- assign rlp_applied = 1 -%}
    {%- assign rlp_out = rlp_cents -%}
  {%- endif -%}
{%- endif -%}
{{- rlp_applied -}}|{{- rlp_out -}}
