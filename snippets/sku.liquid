{%- doc -%}
  This snippet is used to render a product SKU.
  It is used in the sku block.

  @param {product} product_resource - The product to render
  @param {string} [sku] - Optional displayed SKU (e.g. collection card context or lowest sorted). Falls back to selected or first available variant.
{%- enddoc -%}

{%- liquid
  assign sku_display = sku | default: product_resource.selected_or_first_available_variant.sku
-%}

<div ref="skuContainer">
  <span
    class="sku"
    ref="sku"
    data-testid="product-sku"
  >
    {{- sku_display -}}
  </span>
</div>
