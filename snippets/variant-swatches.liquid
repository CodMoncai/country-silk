{%- doc -%}
  Renders a swatches variant picker, used within the product-swatches block.
  A swatch will rendered in a pre-selected state if the context allows it.
  Allowed contexts are search and filtered collections.

  @param {object} product_resource - The product object, which contains variants and options.
  @param {boolean} [has_option_selected] - Whether to render the swatches in a pre-selected state.

  @example
  {% render 'variant-swatches', product_resource: product %}
{%- enddoc -%}

{% liquid
  assign card_swatches_collection = collection
  if card_swatches_collection == blank and closest.collection != blank
    assign card_swatches_collection = closest.collection
  endif
%}
{% capture _theme_sku_layout_flag %}{% render 'collection-theme-sku-layout-active', scope_collection: card_swatches_collection %}{% endcapture %}
{% assign theme_sku_layout_active = false %}
{% if _theme_sku_layout_flag | strip == '1' %}
  {% assign theme_sku_layout_active = true %}
{% endif %}

{% liquid
  # Allow pre-selection of a swatch if there is a selected variant
  # product.selected_variant is automatically set in filtered collection, filtered search and some unfiltered search contexts based on result relevance.
  # Applying a filter updates the displayed image, so a swatch can help communicate the change.
  # Tag-filtered collections also need preselection so card-context variant matches the active swatch (see card-context-variant-id).
  assign allow_preselection = false

  if product_resource.selected_variant or has_option_selected
    assign allow_preselection = true
  endif

  if current_tags != blank and current_tags.size > 0
    assign allow_preselection = true
  endif

  capture storefront_filters_active_flag
    render 'storefront-filters-active'
  endcapture
  assign storefront_filters_active_flag = storefront_filters_active_flag | strip
  if storefront_filters_active_flag == '1'
    assign allow_preselection = true
  endif

  capture _card_context_variant_id
    render 'card-context-variant-id', product: product_resource, current_collection: card_swatches_collection
  endcapture
  assign _card_context_variant_id = _card_context_variant_id | strip
  assign card_context_variant = product_resource.selected_or_first_available_variant
  if _card_context_variant_id != ''
    assign _resolved_card_variant = nil
    assign _want_sw_vid = _card_context_variant_id | strip
    for v in product_resource.variants
      assign _swid_s = v.id | append: ''
      if _swid_s == _want_sw_vid
        assign _resolved_card_variant = v
        break
      endif
    endfor
    if _resolved_card_variant != blank
      assign card_context_variant = _resolved_card_variant
    endif
  endif

  assign card_swatches_theme_option_position = nil
  assign card_swatches_theme_codes = ''
  if theme_sku_layout_active and card_swatches_collection != blank
    for po in product_resource.options_with_values
      assign _po_nm = po.name | downcase | strip
      if _po_nm == 'theme' or _po_nm == 'themes' or _po_nm contains 'theme'
        assign card_swatches_theme_option_position = po.position | plus: 0
        capture card_swatches_theme_codes
          render 'collection-theme-variant-codes', collection: card_swatches_collection
        endcapture
        assign card_swatches_theme_codes = card_swatches_theme_codes | strip
        break
      endif
    endfor
  endif
%}

<swatches-variant-picker-component
  data-product-id="{{ product_resource.id }}"
  data-product-url="{{ product_resource.url }}"
  ref="swatchesVariantPicker"
>
  <form>
    {% comment %}
      Find the first product option that has swatches.
      Then render individual swatches with information on the most relevant variant image to be used in:
      - a data-media-id attribute to show relevant media in a card-gallery on hover/click.
      - the swatch content, optionally based on theme settings.
    {% endcomment %}
    {%- for product_option in product_resource.options_with_values -%}
      {%- liquid
        assign swatch_count = product_option.values | map: 'swatch' | compact | size
      -%}

      {% if swatch_count == 0 %}
        {% continue %}
      {% endif %}

      {%- liquid
        # Identify which option position this swatch option is
        # Use product_option.position which is the actual position among ALL options
        assign swatch_option_position = product_option.position
        assign swatch_option_key = 'option' | append: swatch_option_position
        assign card_swatches_value_order = ''
        assign apply_card_swatches_sku_order = false
        if card_swatches_theme_codes != blank and card_swatches_theme_option_position != nil
          assign _sw_pos = product_option.position | plus: 0
          if _sw_pos == card_swatches_theme_option_position
            capture card_swatches_value_order
              render 'product-option-value-ids-by-theme-sku',
                product: product_resource,
                product_option: product_option,
                codes_line: card_swatches_theme_codes
            endcapture
            assign card_swatches_value_order = card_swatches_value_order | strip
            if card_swatches_value_order != blank
              assign apply_card_swatches_sku_order = true
            endif
          endif
        endif
      -%}

      <fieldset class="variant-option variant-option--buttons variant-option--swatches">
        {% capture children %}
          {%- if apply_card_swatches_sku_order -%}
            {%- assign _swatch_vid_parts = card_swatches_value_order | split: '|' -%}
            {%- assign swatch_input_ix = -1 -%}
            {%- for vid_sw in _swatch_vid_parts -%}
              {%- assign vt_sw = vid_sw | strip -%}
              {%- if vt_sw == blank -%}
                {%- continue -%}
              {%- endif -%}
              {%- for product_option_value in product_option.values -%}
                {%- assign pov_sw = product_option_value.id | append: '' -%}
                {%- if pov_sw != vt_sw -%}
                  {%- continue -%}
                {%- endif -%}
                {%- assign swatch_input_ix = swatch_input_ix | plus: 1 -%}
            {%- liquid
              assign first_available_variant = nil
              assign featured_media = product_option_value.variant.featured_media
              if featured_media == blank
                if product_option_value.variant == blank
                  for variant in product_resource.variants
                    assign variant_opt_for_swatch = ''
                    case swatch_option_position
                      when 1
                        assign variant_opt_for_swatch = variant.option1
                      when 2
                        assign variant_opt_for_swatch = variant.option2
                      when 3
                        assign variant_opt_for_swatch = variant.option3
                    endcase
                    if variant.available and variant_opt_for_swatch == product_option_value.name and variant.featured_media
                      assign featured_media = variant.featured_media
                      assign first_available_variant = variant
                      break
                    endif
                  endfor
                elsif product_option_value.product_url
                  assign featured_media = product_option_value.variant.product.featured_media
                endif
              endif
            %}
            {% liquid
              assign effective_variant_id = first_available_variant.id | default: product_option_value.variant.id
              assign swatch_checked = false
              if allow_preselection and product_option_value.selected
                assign swatch_checked = true
              endif
              if swatch_checked == false and card_context_variant != blank
                if effective_variant_id != blank and effective_variant_id == card_context_variant.id
                  assign swatch_checked = true
                else
                  assign context_opt_for_swatch = ''
                  case swatch_option_position
                    when 1
                      assign context_opt_for_swatch = card_context_variant.option1
                    when 2
                      assign context_opt_for_swatch = card_context_variant.option2
                    when 3
                      assign context_opt_for_swatch = card_context_variant.option3
                  endcase
                  if context_opt_for_swatch == product_option_value.name
                    assign swatch_checked = true
                  endif
                endif
              endif
            %}
            <li class="variant-option__swatch">
              <label
                data-media-id="{{ featured_media.id }}"
                class="variant-option__button-label variant-option__button-label--has-swatch swatch-rounded"
                on:pointerenter="product-card/previewVariant/{{ featured_media.id }}"
                on:pointerleave="product-card/resetVariant"
              >
                <input
                  type="radio"
                  name="{{ product_option.name | escape }}-{{ product_resource.id }}-swatch"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name }}"
                  data-input-id="{{ product_option.position }}-{{ swatch_input_ix }}"
                  data-option-media-id="{{ featured_media.id }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if swatch_checked %}
                    checked
                  {% endif %}
                  data-variant-id="{{ first_available_variant.id | default: product_option_value.variant.id }}"
                  data-first-available-or-first-variant-id="{{ first_available_variant.id | default: product_option_value.variant.id }}"
                >
                {% render 'swatch',
                  swatch: product_option_value.swatch,
                  variant_image: featured_media,
                %}
                {% render 'strikethrough-variant', product_option: product_option_value %}
              </label>
            </li>
              {%- endfor -%}
            {%- endfor -%}
          {%- else -%}
          {%- for product_option_value in product_option.values -%}
            {% liquid
              assign first_available_variant = nil
              comment
                Identify the most relevant variant image to show in a card-gallery, and optionally as the swatch content.
                The `product_option_value.variant` can be nil when no valid variant is associated with the combination of the current option-value and the other option values.
                e.g. a product option Color: "Red" does not exist for the product option Size: "Small".
                In this case, we look for the first available variant in that option (e.g. Color) that has a featured media.
              endcomment

              assign featured_media = product_option_value.variant.featured_media

              if featured_media == blank
                if product_option_value.variant == blank
                  for variant in product_resource.variants
                    assign variant_opt_for_swatch = ''
                    case swatch_option_position
                      when 1
                        assign variant_opt_for_swatch = variant.option1
                      when 2
                        assign variant_opt_for_swatch = variant.option2
                      when 3
                        assign variant_opt_for_swatch = variant.option3
                    endcase
                    if variant.available and variant_opt_for_swatch == product_option_value.name and variant.featured_media
                      assign featured_media = variant.featured_media
                      assign first_available_variant = variant
                      break
                    endif
                  endfor
                elsif product_option_value.product_url
                  # If the variant has no featured media, and we have a combined listing product (product_url exists),
                  # then fall back to using the featured media of the child product that is linked to this option value.
                  assign featured_media = product_option_value.variant.product.featured_media
                endif
              endif
            %}

            {% liquid
              assign effective_variant_id = first_available_variant.id | default: product_option_value.variant.id
              assign swatch_checked = false
              if allow_preselection and product_option_value.selected
                assign swatch_checked = true
              endif
              if swatch_checked == false and card_context_variant != blank
                if effective_variant_id != blank and effective_variant_id == card_context_variant.id
                  assign swatch_checked = true
                else
                  assign context_opt_for_swatch = ''
                  case swatch_option_position
                    when 1
                      assign context_opt_for_swatch = card_context_variant.option1
                    when 2
                      assign context_opt_for_swatch = card_context_variant.option2
                    when 3
                      assign context_opt_for_swatch = card_context_variant.option3
                  endcase
                  if context_opt_for_swatch == product_option_value.name
                    assign swatch_checked = true
                  endif
                endif
              endif
            %}

            <li class="variant-option__swatch">
              <label
                data-media-id="{{ featured_media.id }}"
                class="variant-option__button-label variant-option__button-label--has-swatch swatch-rounded"
                on:pointerenter="product-card/previewVariant/{{ featured_media.id }}"
                on:pointerleave="product-card/resetVariant"
              >
                <input
                  type="radio"
                  name="{{ product_option.name | escape }}-{{ product_resource.id }}-swatch"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name }}"
                  data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                  data-option-media-id="{{ featured_media.id }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if swatch_checked %}
                    checked
                  {% endif %}
                  data-variant-id="{{ first_available_variant.id | default: product_option_value.variant.id }}"
                  data-first-available-or-first-variant-id="{{ first_available_variant.id | default: product_option_value.variant.id }}"
                >
                {% render 'swatch',
                  swatch: product_option_value.swatch,
                  variant_image: featured_media,
                %}
                {% render 'strikethrough-variant', product_option: product_option_value %}
              </label>
            </li>
          {%- endfor -%}
          {%- endif -%}
          <li
            slot="more"
          >
            <button
              class="hidden-swatches__count"
              aria-label="{{ 'actions.show_all_options' | t }}"
              on:click="/showAllSwatches"
            ></button>
          </li>
        {% endcapture %}

        {% render 'overflow-list', children: children, ref: 'overflowList' %}
      </fieldset>
    {%- endfor -%}
    <script type="application/json">
      {{ card_context_variant | json }}
    </script>
  </form>
</swatches-variant-picker-component>
