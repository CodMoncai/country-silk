{%- doc -%}
  Theme variant swatch from a product metafield whose value is multiple Theme Swatch metaobjects (typical), or one metaobject.

  @param {object} theme_entries - Metafield .value (array of entries when list type, or one metaobject)
  @param {boolean} theme_swatches_is_list - True when metafield is a list (list? or type contains list.); false for a single metaobject reference
  @param {string} product_option_value - Theme option value to match
  @param {string} [mode] - Passed to swatch snippet
{%- enddoc -%}

{% liquid
  assign override_background = ''
  assign opt_val = product_option_value | strip
  assign opt_name = product_option_value.name | default: opt_val | strip
%}
{% if theme_entries != blank %}
  {% if theme_swatches_is_list %}
    {% for entry in theme_entries %}
      {% capture piece %}
        {% render 'theme-swatch-entry-override', entry: entry, opt_val: opt_val, opt_name: opt_name %}
      {% endcapture %}
      {% assign piece = piece | strip %}
      {% if piece != blank %}
        {% assign override_background = piece %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% else %}
    {% capture piece %}
      {% render 'theme-swatch-entry-override', entry: theme_entries, opt_val: opt_val, opt_name: opt_name %}
    {% endcapture %}
    {% assign override_background = piece | strip %}
  {% endif %}
{% endif %}
{% render 'swatch', mode: mode, override_background: override_background, skip_image_fallbacks: true %}
