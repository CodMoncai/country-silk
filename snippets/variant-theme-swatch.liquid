{%- doc -%}
  Renders a variant swatch for the Themes option using a product metafield list of metaobjects.

  Expected product metafield: list.metaobject_reference (namespace/key from variant picker block settings).
  Metaobject fields: theme_option_value (single line text), swatch_color (color) before swatch_image (file).

  Variant photos and Shopify option image swatches are skipped; metaobject color/file and native option color (only) may show.

  @param {object} theme_entries - Metafield .value (array of metaobjects)
  @param {string} product_option_value - Option value to match
  @param {string} [mode] - Passed to swatch snippet
{%- enddoc -%}

{% liquid
  assign override_background = ''
  assign opt_val = product_option_value | strip
  assign opt_name = product_option_value.name | default: opt_val | strip
%}
{% if theme_entries != blank %}
  {% for entry in theme_entries %}
    {% liquid
      assign label = entry.theme_option_value | default: entry.option_value | strip
      assign label_n = label | downcase
      assign opt_val_n = opt_val | downcase
      assign opt_name_n = opt_name | downcase
      assign label_matches = false
      if label_n == opt_val_n or label_n == opt_name_n
        assign label_matches = true
      endif
    %}
    {% if label_matches %}
      {% capture color_css %}
        {% render 'metaobject-swatch-color-css', entry: entry %}
      {% endcapture %}
      {% assign color_css = color_css | strip %}
      {% if color_css != blank %}
        {% assign override_background = color_css %}
      {% endif %}
      {% if override_background == blank and entry.swatch_image != blank %}
        {% liquid
          assign swatch_image_width = settings.variant_swatch_width | times: 2
          assign swatch_image_url = entry.swatch_image | image_url: width: swatch_image_width
          assign override_background = 'url(' | append: swatch_image_url | append: ')'
        %}
      {% endif %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}
{% render 'swatch',
  swatch: product_option_value.swatch,
  mode: mode,
  override_background: override_background,
  skip_image_fallbacks: true
%}
